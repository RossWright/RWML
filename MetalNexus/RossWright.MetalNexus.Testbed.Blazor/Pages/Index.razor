    // ══════════════════════════════════════════════════════════════════════════
    // 22. MFA / AllowProvisional
    // ══════════════════════════════════════════════════════════════════════════
    private async Task RunMfaAsync(CancellationToken ct)
    {
        // 1. Get a provisional token
        string provisionalToken;
        try
        {
            var resp = await Http.PostAsJsonAsync("/auth/token", new
            {
                username = "admin",
                password = "admin",
                provisional = true
            }, ct);
            resp.EnsureSuccessStatusCode();
            var tr = await resp.Content.ReadFromJsonAsync<TokenResponse>(cancellationToken: ct);
                provisionalToken = tr?.Token ?? throw new InvalidOperationException("No token returned");
            }
            catch (Exception ex)
            {
                AppendError("MFA — provisional token fetch", ex);
                return;
            }


        try
        {
            // We set the token directly so the auth handler picks it up
            var saved = TokenService.Token;
            var savedUser = TokenService.Username;
            TokenService.SetToken("admin(provisional)", provisionalToken);
            MfaConfirmDto result;
            try { result = await Mediator.Send(new ConfirmMfaRequest { Code = "123456" }, ct); }
            finally
            {
                if (saved is not null) TokenService.SetToken(savedUser, saved);
                else TokenService.ClearToken();
            }
            _log.Append(new LogEntry
            {
                Title     = "AllowProvisional Auth (MFA sim)",
                Feature   = "[Authenticated(AllowProvisional = true)]",
                Narrative = "A provisional token carries the claim auth_level=provisional. Normally protected " +
                            "endpoints reject provisional tokens. [Authenticated(AllowProvisional = true)] " +
                            "opts into accepting them — the typical MFA confirmation step.",
                Code      = "[Authenticated(AllowProvisional = true)]\npublic class ConfirmMfaRequest : IRequest<MfaConfirmDto>",
                Result    = $"Success: {result.Success}  |  {result.Message}",
                Takeaway  = "AllowProvisional = true enables a clean MFA flow without a separate auth scheme."
            });
        }
        catch (Exception ex) { AppendError("MFA — ConfirmMfa call", ex); }
    }


