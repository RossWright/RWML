    // ── helpers ───────────────────────────────────────────────────────────────
    private void AppendError(string title, Exception ex)
    {
        Logger.LogError(ex, "Test function {Title} failed", title);
        _log.Append(new LogEntry
        {
            Title   = title,
            Result  = $"{ex.GetType().Name}: {ex.Message}",
            IsError = true
        });
    }

    private void AppendWarning(string title, string message) =>
        _log.Append(new LogEntry { Title = title, Result = message, IsWarning = true });

    private void AppendSkip(string title, string reason) =>
        _log.Append(new LogEntry { Title = title, Result = $"⏭ Skipped: {reason}", IsWarning = true });
}
